# ============================================================================
# 敏感配置 — 运行时通过 -e 或 --env-file 注入，不进镜像
# ============================================================================
.env

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.git/

# ============================================================================
# 运行时产物 — 目录结构在镜像中通过 .gitkeep 保留，内容不进镜像
# ============================================================================
sandbox_seed/scratch/*
sandbox_seed/outputs/*

# ============================================================================
# IDE / 编辑器
# ============================================================================
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# ============================================================================
# macOS
# ============================================================================
.DS_Store

# ============================================================================
# 仅排除 .gitignore（不进镜像），保留 Dockerfile（langgraph up 需要）
# ============================================================================
.gitignore
