# ============================================================================
# 融资融券交易试算 Agent — 环境变量模板
# 复制为 .env 后填入真实值。.env 已被 .gitignore 排除，不会泄露。
# ============================================================================

# ---------------------------------------------------------------------------
# LLM 基础配置（必填）
# ---------------------------------------------------------------------------
OPENAI_MODEL=
OPENAI_BASE_URL=
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# 代理绕过（内网地址直连）
# ---------------------------------------------------------------------------
INTRANET_HOSTS=127.0.0.1,localhost
NO_PROXY=127.0.0.1,localhost
no_proxy=127.0.0.1,localhost

# ---------------------------------------------------------------------------
# MCP 服务地址（融资融券业务工具）
# ---------------------------------------------------------------------------
MCP_URL=
MCP_API_KEY=
MCP_API_HEADER=Authorization
MCP_API_PREFIX=Bearer
MCP_TOOLS_TIMEOUT_SECONDS=15
MCP_REQUIRED=false

# ---------------------------------------------------------------------------
# LangSmith 可观测性（可选，推荐开启）
# ---------------------------------------------------------------------------
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=pre-trade-agent

# ---------------------------------------------------------------------------
# 沙箱后端
#   SANDBOX_PROVIDER=local   → 本地文件系统（推荐，开发/Docker部署均适用）
#   SANDBOX_PROVIDER=daytona → Daytona 云端沙箱（需额外配置下方 DAYTONA_*）
# ---------------------------------------------------------------------------
SANDBOX_PROVIDER=local
SANDBOX_SEED_DIR=./sandbox_seed
RULES_DIR=./rules

# ---------------------------------------------------------------------------
# Daytona 云端沙箱（仅 SANDBOX_PROVIDER=daytona 时必填）
# ---------------------------------------------------------------------------
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_SNAPSHOT_ID=
DAYTONA_MAX_SANDBOXES=10
DAYTONA_ACTIVE_WINDOW_SECONDS=300

# ---------------------------------------------------------------------------
# 其他
# ---------------------------------------------------------------------------
DEEPAGENT_DEBUG=false
MAX_CLARIFY_ROUNDS=4
